<Window x:Class="ScreenshotTool.CapturePreviewPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        ShowInTaskbar="False" Background="Transparent"
        Width="320" SizeToContent="Height"
        MouseEnter="OnMouseEnter" MouseLeave="OnMouseLeave">
    <Border Background="#F0161B22" BorderBrush="#FF2D3548" BorderThickness="1"
            CornerRadius="12" Padding="16" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <!-- Accent line -->
            <Border Height="3" CornerRadius="2" Margin="0,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#FF38BDF8" Offset="0"/>
                        <GradientStop Color="#FF818CF8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Thumbnail -->
            <Border CornerRadius="8" ClipToBounds="True" MaxHeight="180" Margin="0,0,0,12">
                <Image x:Name="ThumbnailImage" Stretch="Uniform"/>
            </Border>

            <!-- Copied badge -->
            <Border Background="#2010B981" CornerRadius="4" Padding="8,4" Margin="0,0,0,12"
                    HorizontalAlignment="Left">
                <TextBlock Text="Copied to clipboard" FontSize="11"
                           Foreground="#FF10B981" FontWeight="SemiBold"/>
            </Border>

            <!-- File name -->
            <TextBlock x:Name="FileNameText" FontSize="11" Foreground="#FF8B949E"
                       Margin="0,0,0,12" TextTrimming="CharacterEllipsis"/>

            <!-- Action buttons -->
            <UniformGrid Columns="4" Margin="0,0,0,4">
                <Button Content="Edit" Margin="0,0,4,0" Click="Edit_Click"
                        FontSize="12" Padding="0,6"/>
                <Button Content="Save As" Margin="0,0,4,0" Click="SaveAs_Click"
                        FontSize="12" Padding="0,6"/>
                <Button Content="Reveal" Margin="0,0,4,0" Click="Reveal_Click"
                        FontSize="12" Padding="0,6"/>
                <Button Content="Delete" Click="Delete_Click"
                        FontSize="12" Padding="0,6"/>
            </UniformGrid>
        </StackPanel>
    </Border>
</Window>
