<UserControl x:Class="ScreenshotTool.Controls.HotkeyRecorderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             MouseLeftButtonDown="OnClick"
             PreviewKeyDown="OnKeyDown"
             LostFocus="OnLostFocus">
    <Border x:Name="Bd" Background="#FF161B22" BorderBrush="#FF2D3548"
            BorderThickness="1" CornerRadius="6" Padding="12,8" Cursor="Hand"
            MinWidth="160">
        <TextBlock x:Name="ShortcutText" Text="Shift+Ctrl+1"
                   FontFamily="Consolas" FontSize="13"
                   Foreground="#FFE6EDF3" HorizontalAlignment="Center"/>
    </Border>
</UserControl>
