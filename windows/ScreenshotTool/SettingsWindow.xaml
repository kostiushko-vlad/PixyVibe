<Window x:Class="ScreenshotTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ScreenshotTool.Controls"
        Title="PixyVibe Settings" Height="420" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="0">
        <TabControl>
            <!-- Shortcuts Tab -->
            <TabItem Header="Shortcuts">
                <StackPanel Margin="20">
                    <TextBlock Text="Keyboard Shortcuts" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Screenshot:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <controls:HotkeyRecorderControl x:Name="ScreenshotHotkey" Grid.Column="1"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GIF Recording:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <controls:HotkeyRecorderControl x:Name="GifHotkey" Grid.Column="1"/>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Diff:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <controls:HotkeyRecorderControl x:Name="DiffHotkey" Grid.Column="1"/>
                    </Grid>

                    <Button Content="Reset to Defaults" HorizontalAlignment="Left" Click="ResetHotkeys_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Capture Tab -->
            <TabItem Header="Capture">
                <StackPanel Margin="20">
                    <TextBlock Text="GIF Recording" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Frame rate:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <Slider x:Name="FpsSlider" Grid.Column="1" Minimum="5" Maximum="30"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="FpsSlider_ValueChanged"/>
                        <TextBlock x:Name="FpsLabel" Grid.Column="2" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max duration:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <Slider x:Name="DurationSlider" Grid.Column="1" Minimum="5" Maximum="120"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="DurationSlider_ValueChanged"/>
                        <TextBlock x:Name="DurationLabel" Grid.Column="2" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>

                    <TextBlock Text="Image Processing" FontSize="15" FontWeight="SemiBold" Margin="0,16,0,16"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max width:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <Slider x:Name="MaxWidthSlider" Grid.Column="1" Minimum="640" Maximum="3840"
                                TickFrequency="128" IsSnapToTickEnabled="True"
                                ValueChanged="MaxWidthSlider_ValueChanged"/>
                        <TextBlock x:Name="MaxWidthLabel" Grid.Column="2" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="JPEG quality:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <Slider x:Name="QualitySlider" Grid.Column="1" Minimum="50" Maximum="100"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="QualitySlider_ValueChanged"/>
                        <TextBlock x:Name="QualityLabel" Grid.Column="2" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- Output Tab -->
            <TabItem Header="Output">
                <StackPanel Margin="20">
                    <TextBlock Text="Save Location" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SavePath" IsReadOnly="True"/>
                        <Button Content="Browse..." Grid.Column="1" Margin="8,0,0,0" Click="Browse_Click"/>
                    </Grid>

                    <TextBlock Text="Cleanup" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <CheckBox x:Name="AutoCleanupCheck" Content="Auto-delete old captures" Margin="0,0,0,12"
                              Checked="AutoCleanup_Changed" Unchecked="AutoCleanup_Changed"/>

                    <Grid x:Name="CleanupAgePanel" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Delete after:" VerticalAlignment="Center" Foreground="#FF8B949E"/>
                        <Slider x:Name="CleanupSlider" Grid.Column="1" Minimum="1" Maximum="365"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="CleanupSlider_ValueChanged"/>
                        <TextBlock x:Name="CleanupLabel" Grid.Column="2" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
