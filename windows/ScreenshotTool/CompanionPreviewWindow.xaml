<Window x:Class="ScreenshotTool.CompanionPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Companion Preview" Width="420" Height="760"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#FF161B22" BorderBrush="#FF2D3548"
                BorderThickness="0,0,0,1" Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="#FF8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="DeviceNameText" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#FFE6EDF3"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Preview area -->
        <Grid Grid.Row="1" Background="#FF0D0F14">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>

            <!-- Region selection overlay -->
            <Canvas x:Name="RegionCanvas" Background="Transparent" Cursor="Cross"
                    MouseLeftButtonDown="Preview_MouseDown"
                    MouseMove="Preview_MouseMove"
                    MouseLeftButtonUp="Preview_MouseUp"/>

            <!-- Connection overlay -->
            <Border x:Name="ConnectionOverlay" Background="#CC0D0F14" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="OverlayTitle" Text="Waiting for broadcast..."
                               FontSize="16" Foreground="#FF8B949E" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="OverlaySubtitle"
                               Text="Accept the broadcast request on your device"
                               FontSize="12" Foreground="#FF8B949E" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom toolbar — matches macOS companion toolbar -->
        <Border Grid.Row="2" Background="#E8161B22" BorderBrush="#40FFFFFF"
                BorderThickness="0,0.5,0,0" Padding="12,6">
            <StackPanel x:Name="ToolbarPanel" Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Screenshot button -->
                <Border x:Name="BtnScreenshot" Cursor="Hand" CornerRadius="6" Padding="10,6"
                        MouseLeftButtonDown="Mode_Screenshot">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="LblScreenshot" Text="Screenshot" FontSize="11" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Width="1" Background="#15FFFFFF" Margin="2,4"/>

                <!-- Record GIF button -->
                <Border x:Name="BtnGif" Cursor="Hand" CornerRadius="6" Padding="10,6"
                        MouseLeftButtonDown="Mode_Gif">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="LblGif" Text="Record GIF" FontSize="11" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Area toggle (shown in GIF mode) -->
                <Border x:Name="AreaDivider" Width="1" Background="#15FFFFFF" Margin="2,4" Visibility="Collapsed"/>
                <Border x:Name="BtnFull" Cursor="Hand" CornerRadius="5" Padding="8,5"
                        MouseLeftButtonDown="Area_Full" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8EA;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="Full" FontSize="10" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border x:Name="BtnRegion" Cursor="Hand" CornerRadius="5" Padding="8,5"
                        MouseLeftButtonDown="Area_Region" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE123;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="Region" FontSize="10" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Start/Stop button -->
                <Border x:Name="StartDivider" Width="1" Background="#15FFFFFF" Margin="2,4" Visibility="Collapsed"/>
                <Border x:Name="BtnStart" Cursor="Hand" CornerRadius="6" Padding="10,5"
                        MouseLeftButtonDown="Start_Click" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0" Foreground="White"/>
                        <TextBlock x:Name="LblStart" Text="Start" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
