<Window x:Class="ScreenshotTool.CompanionPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Companion Preview" Width="420" Height="720"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FF161B22" BorderBrush="#FF2D3548"
                BorderThickness="0,0,0,1" Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="#FF8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="DeviceNameText" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <RadioButton x:Name="ModeScreenshot" Content="Screenshot" GroupName="CMode"
                                 IsChecked="True" Margin="0,0,8,0"
                                 Style="{StaticResource ToolbarButton}"/>
                    <RadioButton x:Name="ModeGif" Content="GIF" GroupName="CMode"
                                 Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Preview area -->
        <Grid Grid.Row="1" Background="#FF0D0F14">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>

            <!-- Connection overlay -->
            <Border x:Name="ConnectionOverlay" Background="#CC0D0F14"
                    Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="OverlayTitle" Text="Waiting for broadcast..."
                               FontSize="16" Foreground="#FF8B949E" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="OverlaySubtitle"
                               Text="Start broadcasting from your companion app"
                               FontSize="12" Foreground="#FF8B949E" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Region selection overlay -->
            <Canvas x:Name="RegionCanvas" Background="Transparent" Visibility="Collapsed"
                    MouseLeftButtonDown="Region_MouseDown"
                    MouseMove="Region_MouseMove"
                    MouseLeftButtonUp="Region_MouseUp"/>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="#FF161B22" BorderBrush="#FF2D3548"
                BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <RadioButton x:Name="AreaFull" Content="Full Screen" GroupName="Area"
                                 IsChecked="True" Margin="0,0,8,0"
                                 Click="Area_Changed"
                                 Style="{StaticResource ToolbarButton}"/>
                    <RadioButton x:Name="AreaRegion" Content="Region" GroupName="Area"
                                 Click="Area_Changed"
                                 Style="{StaticResource ToolbarButton}"/>
                </StackPanel>

                <Button x:Name="CaptureBtn" Content="Capture" DockPanel.Dock="Right"
                        HorizontalAlignment="Right" Style="{StaticResource AccentButton}"
                        Click="Capture_Click"/>
            </DockPanel>
        </Border>
    </Grid>

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFE6EDF3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A3040"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1C2333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
