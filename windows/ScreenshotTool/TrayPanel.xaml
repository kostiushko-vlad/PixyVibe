<Window x:Class="ScreenshotTool.TrayPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        ShowInTaskbar="False" Background="Transparent"
        Width="340" SizeToContent="Height"
        Deactivated="Window_Deactivated">
    <Border Background="#F0161B22" BorderBrush="#FF2D3548" BorderThickness="1"
            CornerRadius="12" Padding="16" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="PixyVibe" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#FF38BDF8" Offset="0"/>
                        <GradientStop Color="#FF818CF8" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Devices section -->
            <TextBlock x:Name="DevicesHeader" Text="PAIRED DEVICES" FontSize="10" FontWeight="SemiBold"
                       Foreground="#FF8B949E" Margin="0,0,0,8" Visibility="Collapsed"/>
            <ScrollViewer x:Name="DevicesScroller" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled" Margin="0,0,0,12" Visibility="Collapsed">
                <StackPanel x:Name="DevicesContainer" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- Recent captures -->
            <TextBlock Text="RECENT CAPTURES" FontSize="10" FontWeight="SemiBold"
                       Foreground="#FF8B949E" Margin="0,0,0,8"/>

            <Grid x:Name="HistoryGrid" Margin="0,0,0,12">
                <!-- Populated dynamically -->
            </Grid>

            <TextBlock x:Name="EmptyHistoryText" Text="No captures yet"
                       FontSize="12" Foreground="#FF8B949E" Margin="0,0,0,12"
                       HorizontalAlignment="Center"/>

            <!-- Action bar -->
            <Border BorderBrush="#FF2D3548" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                <UniformGrid Columns="5">
                    <Button Content="Capture" Click="Capture_Click" FontSize="11" Padding="4,6"/>
                    <Button Content="Clear" Click="Clear_Click" FontSize="11" Padding="4,6" Margin="4,0"/>
                    <Button Content="Folder" Click="Folder_Click" FontSize="11" Padding="4,6"/>
                    <Button Content="Settings" Click="Settings_Click" FontSize="11" Padding="4,6" Margin="4,0"/>
                    <Button Content="Quit" Click="Quit_Click" FontSize="11" Padding="4,6"/>
                </UniformGrid>
            </Border>
        </StackPanel>
    </Border>
</Window>
